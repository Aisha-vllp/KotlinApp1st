<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="AnswerButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:backgroundTint">#D32F2F</item> <!-- Красный цвет -->
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
        <item name="android:elevation">8dp</item> <!-- Больше тени для 3D -->
        <item name="android:padding">12dp</item>
        <item name="android:background">@drawable/red_button_bg</item>
    </style>

    <style name="HelpButtonStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">6dp</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:background">@drawable/bg_help_button</item>
        <item name="android:padding">8dp</item>
    </style>




</resources>