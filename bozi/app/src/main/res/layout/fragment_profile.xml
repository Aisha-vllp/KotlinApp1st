<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Кнопка настроек -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/btnSettings"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_settings"
                android:contentDescription="Настройки" />
        </LinearLayout>

        <!-- Серия -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/header_bg"
            android:padding="16dp"
            android:elevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_hammer" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Серия"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/seriesCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 дней подряд"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:textColor="#FF6B00" />

            <!-- Дни недели -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/dayMon"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="Пн\n11"
                    android:gravity="center"
                    android:background="@drawable/bg_day_default"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/dayTue"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="Вт\n12"
                    android:gravity="center"
                    android:background="@drawable/bg_day_default"
                    android:textColor="#B3B3B3"
                    android:textSize="14sp"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/dayWed"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="Ср\n13"
                    android:gravity="center"
                    android:background="@drawable/bg_day_default"
                    android:textColor="#B3B3B3"
                    android:textSize="14sp"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/dayThu"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="Чт\n14"
                    android:gravity="center"
                    android:background="@drawable/bg_day_default"
                    android:textColor="#B3B3B3"
                    android:textSize="14sp"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/dayFri"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="Пт\n15"
                    android:gravity="center"
                    android:background="@drawable/bg_day_default"
                    android:textColor="#B3B3B3"
                    android:textSize="14sp"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/daySat"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="Сб\n16"
                    android:gravity="center"
                    android:background="@drawable/bg_day_default"
                    android:textColor="#B3B3B3"
                    android:textSize="14sp"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/daySun"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="Вс\n17"
                    android:gravity="center"
                    android:background="@drawable/bg_day_default"
                    android:textColor="#B3B3B3"
                    android:textSize="14sp"
                    android:padding="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Прогресс -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/answer_button_default"
            android:padding="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Прогресс"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>

            <!-- Миллионер -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_rounded_orange"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="МИЛЛИОНЕР"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/millionerProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="13 / 100%"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="УРОВЕНЬ 1"
                    android:textColor="#DDAA99"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp"/>

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_games"
                    android:contentDescription="Chest" />
            </LinearLayout>

            <!-- Логика -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_rounded_orange"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Тетрис"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/logicProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15 / 100%"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="УРОВЕНЬ 1"
                    android:textColor="#DDAA99"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp"/>

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_games"
                    android:contentDescription="Chest" />
            </LinearLayout>

            <!-- Фокусировка -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_rounded_orange"
                android:padding="12dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2048"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/focusProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 100%"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="УРОВЕНЬ 1"
                    android:textColor="#DDAA99"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp"/>

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_games"
                    android:contentDescription="Chest" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
